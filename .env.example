# GNG Platform — Environment Variables
# Copy to .env and adjust as needed.
#
# Port scheme (67xx range to avoid conflicts):
#   6730  Frontend (Next.js)
#   6731  API (Go)
#   6732  MongoDB
#   6733  MinIO API
#   6734  MinIO Console
#   6735  Redis
#   6736  Ollama (optional)

# Core
ENVIRONMENT=development

# Server
SERVER_PORT=8009

# Database (MongoDB)
# Docker Compose: mongodb://mongo:27017/    (host port: 6732)
# Local dev:      mongodb://localhost:6732/
DB_URI=mongodb://localhost:6732/
DB_NAME=gngdb

# Hot Storage (MinIO/S3)
# Docker Compose: minio:9000      (host port: 6733, console: 6734)
# Local dev:      localhost:6733
STORAGE_ENDPOINT=localhost:6733
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=artifacts
STORAGE_REGION=us-east-1
STORAGE_SECURE=false

# Archive Storage
ARCHIVE_PROVIDER=minio-archive
ARCHIVE_BUCKET=archive
GLOBUS_ENABLED=false
GLOBUS_ENDPOINT_ID=
GLOBUS_BASE_PATH=
GLOBUS_CLIENT_ID=
GLOBUS_CLIENT_SECRET=

# Pipeline
PIPELINE_PROVIDER=redis-queue
# Docker Compose: redis://redis:6379/0    (host port: 6735)
# Local dev:      redis://localhost:6735/0
REDIS_URL=redis://localhost:6735/0
PIPELINE_CALLBACK_SECRET=dev-secret-change-me
PIPELINE_CALLBACK_URL=http://localhost:6731

# Processing
PROCESSING_ENABLE_TRANSCRIPTION=false
PROCESSING_ENABLE_METADATA_EXTRACTION=true
PROCESSING_ENABLE_LLM_ENRICHMENT=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:6730
