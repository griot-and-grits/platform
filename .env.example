# GNG Platform — Environment Variables
# Copy to .env and adjust as needed.

# Core
ENVIRONMENT=development

# Server
SERVER_PORT=8009

# Database (MongoDB)
# Docker Compose: mongodb://mongo:27017/
# Local dev:      mongodb://localhost:27017/
DB_URI=mongodb://localhost:27017/
DB_NAME=gngdb

# Hot Storage (MinIO/S3)
# Docker Compose: minio:9000
# Local dev:      localhost:9000
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=artifacts
STORAGE_REGION=us-east-1
STORAGE_SECURE=false

# Archive Storage
ARCHIVE_PROVIDER=minio-archive
ARCHIVE_BUCKET=archive
GLOBUS_ENABLED=false
GLOBUS_ENDPOINT_ID=
GLOBUS_BASE_PATH=
GLOBUS_CLIENT_ID=
GLOBUS_CLIENT_SECRET=

# Pipeline
PIPELINE_PROVIDER=redis-queue
REDIS_URL=redis://localhost:6379/0
PIPELINE_CALLBACK_SECRET=dev-secret-change-me
PIPELINE_CALLBACK_URL=http://localhost:8009

# Processing
PROCESSING_ENABLE_TRANSCRIPTION=false
PROCESSING_ENABLE_METADATA_EXTRACTION=true
PROCESSING_ENABLE_LLM_ENRICHMENT=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
